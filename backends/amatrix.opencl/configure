#!/bin/sh
# amatrix.opencl configure.
#
# There is deliberately NO compile-time detection of OpenCL or CLBlast: both
# are resolved at run time by src/amatrix_cl_loader.c, and the package must
# build identically on machines with and without a GPU SDK. This script only
# materialises src/Makevars from the checked-in src/Makevars.in template, so it
# cannot probe hardware, cannot fail on a headless builder, and never aborts.
set -eu

cp "src/Makevars.in" "src/Makevars"

exit 0
