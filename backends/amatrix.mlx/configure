#!/bin/sh

set -eu

src_dir="src"
makevars="${src_dir}/Makevars"
prefix=""

if [ -n "${MLX_C_PREFIX:-}" ] && [ -d "${MLX_C_PREFIX}" ]; then
  prefix="${MLX_C_PREFIX}"
elif command -v brew >/dev/null 2>&1; then
  maybe_prefix="$(brew --prefix mlx-c 2>/dev/null || true)"
  if [ -n "${maybe_prefix}" ] && [ -d "${maybe_prefix}" ]; then
    prefix="${maybe_prefix}"
  fi
fi

if [ -n "${prefix}" ] && [ -f "${prefix}/include/mlx/c/mlx.h" ] && [ -f "${prefix}/lib/libmlxc.dylib" ]; then
  # libmlxc links against the MLX C++ core (libmlx). Derive its prefix from
  # MLX_PREFIX or Homebrew, and only append the extra -L/-rpath when it
  # resolves so a missing brew doesn't emit a bogus "-L/lib" flag.
  mlx_core_prefix=""
  if [ -n "${MLX_PREFIX:-}" ] && [ -d "${MLX_PREFIX}" ]; then
    mlx_core_prefix="${MLX_PREFIX}"
  elif command -v brew >/dev/null 2>&1; then
    maybe_core="$(brew --prefix mlx 2>/dev/null || true)"
    if [ -n "${maybe_core}" ] && [ -d "${maybe_core}" ]; then
      mlx_core_prefix="${maybe_core}"
    fi
  fi

  mlx_prefix_escaped="$(printf '%s' "${prefix}" | sed 's/[\/&]/\\&/g')"
  mlx_libs="-L${mlx_prefix_escaped}/lib -Wl,-rpath,${mlx_prefix_escaped}/lib"
  if [ -n "${mlx_core_prefix}" ]; then
    core_escaped="$(printf '%s' "${mlx_core_prefix}" | sed 's/[\/&]/\\&/g')"
    mlx_libs="${mlx_libs} -L${core_escaped}/lib -Wl,-rpath,${core_escaped}/lib"
  fi
  mlx_libs="${mlx_libs} -lmlxc"

  sed \
    -e "s|@MLX_CPPFLAGS@|-DHAVE_MLXC -I${mlx_prefix_escaped}/include|g" \
    -e "s|@MLX_LIBS@|${mlx_libs}|g" \
    "${src_dir}/Makevars.in" > "${makevars}"
  echo "configure: using mlx-c from ${prefix}"
else
  sed \
    -e "s|@MLX_CPPFLAGS@||g" \
    -e "s|@MLX_LIBS@||g" \
    "${src_dir}/Makevars.in" > "${makevars}"
  echo "configure: mlx-c not found, building mock bridge only"
fi
