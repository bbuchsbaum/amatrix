
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.omc/
**/.omc/

# Machine-local benchmark baseline (regenerate with: Rscript tools/benchmark-regression.R --update)
tools/baseline.csv

# Compiled build artifacts
src/*.o
src/*.so
backends/*/src/*.o
backends/*/src/*.so

# Machine-specific Makevars generated by each backend's configure script
# (regenerated at build time from src/Makevars.in; only Makevars.in is tracked)
backends/*/src/Makevars
/doc/
/Meta/

# Local editor/tool backups
.albersdown.bak/
vendor/
/tmp/
repro-*.sessionInfo.txt
sessionInfo-probe*.txt
amatrix_*.tar.gz
tools/benchmark-results/
amatrix.models_*.tar.gz
*.Rcheck/
